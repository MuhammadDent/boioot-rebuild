{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}"
  },
  "JwtSettings": {
    "SecretKey": "boioot-dev-secret-key-change-in-production-must-be-at-least-32-chars",
    "Issuer": "boioot.com",
    "Audience": "boioot-users",
    "TokenExpirationMinutes": 1440,
    "RefreshTokenExpirationDays": 30
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5173",
    "https://*.replit.app"
  ]
}
